# Warehouse Environment — Environment Variables Configuration
# Copy this file to .env and fill in your actual values
# 
# Required for inference.py and baseline testing

# ─── LLM API Configuration ───────────────────────────────

# API endpoint for your LLM service
# Examples:
#   - OpenAI: https://api.openai.com/v1
#   - HuggingFace Inference API: https://api-inference.huggingface.co
#   - Local LM Studio: http://localhost:1234/v1
API_BASE_URL=https://api.openai.com/v1

# Model identifier to use for inference
# Examples:
#   - gpt-4o-mini (OpenAI)
#   - Qwen/Qwen2.5-72B-Instruct (HuggingFace)
#   - meta-llama/Llama-2-7b-chat (HuggingFace)
#   - local-model (LM Studio)
MODEL_NAME=gpt-4o-mini

# ─── Authentication ─────────────────────────────────────

# Your API key / authentication token
# For OpenAI: your OpenAI API key
# For HuggingFace: your HuggingFace API token (hf_...)
# For LM Studio: not needed (leave empty)
HF_TOKEN=your-api-key-here

# ─── Environment URL (Optional) ──────────────────────────

# URL where your Warehouse Environment is running
# Default: http://localhost:8000
# For HuggingFace Space: https://sai1017-warehouse-env.hf.space
ENV_URL=http://localhost:8000

# ─── Optional: Inference Parameters ─────────────────────

# Maximum number of LLM steps per task (default: 50)
# MAX_AGENT_STEPS=50

# Temperature for LLM sampling (default: 0.1, range: 0.0-1.0)
# Lower = more deterministic, Higher = more creative
# TEMPERATURE=0.1

# Maximum tokens per LLM response (default: 256)
# MAX_TOKENS=256
